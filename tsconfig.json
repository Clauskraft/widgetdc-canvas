{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "paths": {
      "@/*": [
        "./src/*"
      ]
    },
    "baseUrl": "."
  },
  "include": [
    "src"
  ],
  "exclude": [
    "src/**/*.test.ts",
    "src/**/*.test.tsx",
    "src/test",
    "**/*.test.ts",
    "**/*.test.tsx",
    "dockerRuntimePackaging.test.ts",
    "serverRuntime.test.ts",
    "src/components/BriefBar.tsx",
    "src/components/ComposeOpsDock.tsx",
    "src/components/HostMessageToast.tsx",
    "src/components/RationaleStrip.tsx",
    "src/panes/ArchitectureSpecPane.tsx",
    "src/panes/EvidencePane.tsx",
    "src/panes/GraphTelemetryPane.tsx",
    "src/panes/ResearchPane.tsx",
    "src/panes/TimelinePane.tsx"
  ]
}
